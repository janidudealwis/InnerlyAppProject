<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Innerly" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">@color/background_warm</item>
        <item name="android:statusBarColor">@color/background_warm</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Hamburger icon color -->
        <item name="drawerArrowStyle">@style/DrawerArrowStyle</item>
        <!-- Toolbar background -->
        <item name="android:actionBarStyle">@style/ToolbarTheme</item>
    </style>

    <style name="DrawerArrowStyle" parent="Widget.AppCompat.DrawerArrowToggle">
        <item name="color">@color/text_black</item>
    </style>

    <style name="ToolbarTheme" parent="Widget.AppCompat.ActionBar">
        <item name="android:background">@color/background_warm</item>
        <item name="elevation">0dp</item>
    </style>
</resources>